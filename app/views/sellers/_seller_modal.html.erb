<!-- Modal -->
<div id="seller-modal" class="modal-overlay" style="display:none">
  <div class="modal">

    <div class="modal-header">
      <h2>Neuer Absender</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('seller-modal').style.display='none'">✕</button>
    </div>

    <%= form_with(model: Seller.new, url: sellers_path, html: { data: { turbo: false } }) do |f| %>

      <div class="modal-body">

        <div class="form-field">
          <%= f.label :name, "Name / Firma" %>
          <%= f.text_field :name, class: "form-input", placeholder: "Max Mustermann / Muster GmbH" %>
        </div>

        <div class="form-row">
          <div class="form-field">
            <%= f.label :street, "Straße" %>
            <%= f.text_field :street, class: "form-input", placeholder: "Musterstraße 1" %>
          </div>
          <div class="form-field">
            <%= f.label :postal_code, "PLZ" %>
            <%= f.text_field :postal_code, class: "form-input", placeholder: "12345" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <%= f.label :city, "Stadt" %>
            <%= f.text_field :city, class: "form-input", placeholder: "München" %>
          </div>
          <div class="form-field">
            <%= f.label :country_code, "Land" %>
            <%= f.select :country_code,
                [["Deutschland", "DE"], ["Österreich", "AT"], ["Schweiz", "CH"]],
                { selected: "DE" },
                class: "form-input" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <%= f.label :tax_id, "Steuernummer" %>
            <%= f.text_field :tax_id, class: "form-input", placeholder: "12/345/67890" %>
          </div>
          <div class="form-field">
            <%= f.label :vat_id, "USt-IdNr." %>
            <%= f.text_field :vat_id, class: "form-input", placeholder: "DE123456789" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <%= f.label :email, "E-Mail" %>
            <%= f.email_field :email, class: "form-input", placeholder: "info@firma.de" %>
          </div>
          <div class="form-field">
            <%= f.label :phone, "Telefon" %>
            <%= f.phone_field :phone, class: "form-input", placeholder: "+49 89 123456" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <%= f.label :iban, "IBAN" %>
            <%= f.text_field :iban, class: "form-input", placeholder: "DE89 3704 0044 0532 0130 00" %>
          </div>
          <div class="form-field">
            <%= f.label :bic, "BIC" %>
            <%= f.text_field :bic, class: "form-input", placeholder: "COBADEFFXXX" %>
          </div>
        </div>

      </div>

      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="document.getElementById('seller-modal').style.display='none'">Abbrechen</button>
        <%= f.submit "Absender speichern", class: "btn-save" %>
      </div>

    <% end %>

  </div>
</div>

<style>
  .btn-new-seller {
    background: none;
    border: 1px dashed #ccc;
    border-radius: 7px;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    color: #666;
    cursor: pointer;
    transition: all 0.15s;
    margin-top: 0.5rem;
  }
  .btn-new-seller:hover { border-color: #111; color: #111; }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fadeIn 0.15s ease;
  }

  .modal {
    background: white;
    border-radius: 12px;
    width: 100%;
    max-width: 560px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    animation: slideUp 0.2s ease;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .modal-header h2 { font-size: 1rem; font-weight: 600; }

  .modal-close {
    background: none;
    border: none;
    font-size: 1rem;
    color: #999;
    cursor: pointer;
    transition: color 0.15s;
  }
  .modal-close:hover { color: #111; }

  .modal-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-field label { font-size: 0.8rem; font-weight: 500; color: #444; }

  .form-input {
    border: 1px solid #e5e5e5;
    border-radius: 7px;
    padding: 0.6rem 0.8rem;
    font-size: 0.88rem;
    font-family: sans-serif;
    color: #111;
    outline: none;
    width: 100%;
    transition: border-color 0.15s;
    appearance: none;
  }
  .form-input:focus { border-color: #111; }
  .form-input::placeholder { color: #bbb; }

  .modal-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid #e5e5e5;
  }

  .btn-save {
    background: #111;
    color: white;
    border: none;
    border-radius: 7px;
    padding: 0.65rem 1.5rem;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-save:hover { opacity: 0.8; }

  .btn-cancel {
    background: none;
    border: none;
    font-size: 0.88rem;
    color: #999;
    cursor: pointer;
    transition: color 0.15s;
  }
  .btn-cancel:hover { color: #111; }

  @keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
  }

  @keyframes slideUp {
    from { transform: translateY(16px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
</style>

<script>
  document.getElementById("seller-modal").addEventListener("click", function(e) {
    if (e.target === this) this.style.display = "none";
  });
</script>
