<div class="item-row">
  <%= f.hidden_field :_destroy, class: "destroy-field" %>

  <%= f.text_field :description,
      placeholder: "Beschreibung",
      class: "form-input" %>

  <%= f.number_field :quantity,
      placeholder: "1",
      step: "0.01",
      value: f.object.quantity || 1,
      class: "form-input" %>

  <%= f.select :unit_code,
      [["Stück", "C62"], ["Stunde", "HUR"], ["Tag", "DAY"], ["Monat", "MON"]],
      { selected: f.object.unit_code || "C62" },
      class: "form-input" %>

  <%= f.number_field :unit_price,
      placeholder: "0.00",
      step: "0.01",
      class: "form-input item-price" %>

  <%= f.select :tax_rate,
      [["19%", 19], ["7%", 7], ["0%", 0]],
      { selected: f.object.tax_rate || 19 },
      class: "form-input item-tax" %>

  <span class="item-total">€ 0.00</span>

  <button type="button" class="btn-remove-item"
    onclick="this.closest('.item-row').remove(); updateTotals()">✕</button>
</div>